<!DOCTYPE html>
<html lang="ja">
<head><meta charset="UTF-8"><title>ユーザー一覧</title></head>
<body>
  <h1>ユーザー一覧（本番DB接続中）</h1>
  <ul>
    <% users.forEach(user => { %>
      <li><%= user.name %> (<%= user.age ? user.age + '歳' : '年齢未設定' %>) (ID: <%= user.id %>)</li>
    <% }) %>
  </ul>
  <h2>ユーザー追加</h2>
  <form action="/users" method="post">
    <input type="text" name="name" placeholder="名前を入力" required>
    <button type="submit">追加する</button>
  </form>
</body>
</html>
